{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@plugins/*": ["plugins/*"],
      "@types/*": ["types/*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ]
  },
  "include": [
    "src/**/*",
    "core/**/*",
    "plugins/**/*"
  ],
  "exclude": [
    "node_modules",
    "plugins/**/node_modules",
    "plugins/**/dist",
    "plugins/**/src"
  ]
}
